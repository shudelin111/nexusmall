<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexusmall.product.dao.BrandMapper">

    <resultMap id="BaseResultMap" type="com.nexusmall.product.entity.Brand">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="logo" property="logo"/>
        <result column="description" property="description"/>
        <result column="first_letter" property="firstLetter"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, logo, description, first_letter, sort_order, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM brand
        WHERE id = #{id}
    </select>

    <select id="list" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM brand
        ORDER BY sort_order ASC, create_time DESC
    </select>

    <select id="selectByName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM brand
        WHERE name = #{name}
    </select>

    <insert id="insert" parameterType="com.nexusmall.product.entity.Brand" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO brand (
            name, logo, description, first_letter, sort_order, status
        ) VALUES (
            #{name}, #{logo}, #{description}, #{firstLetter}, #{sortOrder}, #{status}
        )
    </insert>

    <update id="updateById" parameterType="com.nexusmall.product.entity.Brand">
        UPDATE brand
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="logo != null">logo = #{logo},</if>
            <if test="description != null">description = #{description},</if>
            <if test="firstLetter != null">first_letter = #{firstLetter},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM brand WHERE id = #{id}
    </delete>

    <select id="listByStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM brand
        WHERE status = #{status}
        ORDER BY sort_order ASC
    </select>

    <select id="listByFirstLetter" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM brand
        WHERE first_letter = #{firstLetter}
        ORDER BY sort_order ASC
    </select>
</mapper>

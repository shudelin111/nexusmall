<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 包含 Spring Boot 默认配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 定义日志输出格式 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n"/>

    <!-- 使用 Spring Boot 2.7+ 推荐的属性 -->
    <springProperty scope="context" name="LOG_PATH" source="nexusmall.logging.path" defaultValue="./logs"/>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="app"/>

    <!-- 动态日志路径 -->
    <property name="SERVICE_LOG_PATH" value="${LOG_PATH}/${APP_NAME}"/>

    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 滚动文件输出 -->
    <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${SERVICE_LOG_PATH}/%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 环境控制 -->
    <springProfile name="dev">
        <!-- Seata 详细日志配置 -->
        <logger name="io.seata" level="DEBUG"/>
        <logger name="io.seata.core.rpc" level="DEBUG"/>
        <logger name="io.seata.core.protocol" level="DEBUG"/>
        <logger name="io.seata.rm" level="DEBUG"/>
        <logger name="io.seata.rm.datasource" level="DEBUG"/>
        <logger name="io.seata.rm.datasource.undo" level="DEBUG"/>
        <logger name="io.seata.tm" level="DEBUG"/>
        <logger name="io.seata.spring.annotation" level="DEBUG"/>
        <logger name="io.seata.sqlparser" level="DEBUG"/>
        <logger name="io.seata.core.context" level="DEBUG"/>
        
        <!-- MyBatis SQL 执行日志 -->
        <logger name="com.nexusmall.product.config.SeataHandlerInterceptor" level="DEBUG"/>
        <logger name="com.nexusmall.product.config.WebConfig" level="DEBUG"/>
        
        <!-- Druid 连接池日志 -->
        <logger name="com.alibaba.druid.pool" level="DEBUG"/>
        
        <root level="INFO">
            <appender-ref ref="console"/>
            <appender-ref ref="file"/>
        </root>
    </springProfile>

    <springProfile name="prod,test">
        <root level="INFO">
            <appender-ref ref="file"/>
        </root>
    </springProfile>
</configuration>

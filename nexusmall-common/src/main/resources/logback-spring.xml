<?xml version="1.0" encoding="UTF-8"?>
<!-- =====================================================
     NexusMall 统一日志配置文件（基于 Logback）
     =====================================================
     职责说明：
     1. 定义统一的日志输出格式
     2. 配置日志文件滚动策略（按日期 + 大小）
     3. 分环境控制日志级别（dev/test/prod）
     4. 集成 Spring Boot 动态属性
     ===================================================== -->
<configuration>
    <!-- 包含 Spring Boot 默认日志配置 -->
    <!-- 作用：继承 Spring Boot 的基础日志能力 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ===============================
         自定义日志属性
         =============================== -->

    <!-- 定义日志输出格式（Pattern） -->
    <!-- 格式说明：
         %d{yyyy-MM-dd HH:mm:ss.SSS} - 时间戳（精确到毫秒）
         [%thread]                   - 线程名
         [%X{traceId:-},%X{spanId:-}] - 链路追踪 ID（Sleuth 自动注入，如果没有则为空）
         %-5level                    - 日志级别（左对齐，占 5 字符）
         %logger{50}                 - 类名（最多显示 50 个字符）
         %msg                        - 日志消息
         %n                          - 换行符
         
         示例输出：
         2026-03-25 14:30:00.123 [main] [abc123def456,789xyz] INFO  c.n.auth.controller.LoginController - 用户登录成功
         2026-03-25 14:30:00.123 [main] [,] INFO  c.n.auth.controller.LoginController - 启动阶段无 traceId
    -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-},%X{spanId:-}] %-5level %logger{50} - %msg%n"/>

    <!-- 从 application.yaml 中读取日志路径配置 -->
    <!-- 
         springProperty: Spring Boot 提供的标签，可从配置文件中读取属性
         scope="context": 属性作用域为整个上下文
         name="LOG_PATH": 定义变量名
         source="nexusmall.logging.path": 对应的配置文件属性
         defaultValue="./logs": 默认值（当配置文件中未设置时使用）
    -->
    <springProperty scope="context" name="LOG_PATH" source="nexusmall.logging.path" defaultValue="./logs"/>

    <!-- 读取应用名称（用于日志文件命名） -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="app"/>

    <!-- 动态计算服务日志路径 -->
    <!-- 最终路径示例：D:/IdeaProjects/nexusmall/logs/nexusmall-auth -->
    <property name="SERVICE_LOG_PATH" value="${LOG_PATH}/${APP_NAME}"/>

    <!-- ===============================
         Appender 配置（日志输出目的地）
         =============================== -->

    <!-- 控制台输出（Console） -->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 使用上面定义的日志格式 -->
            <pattern>${LOG_PATTERN}</pattern>
            <!-- 字符编码（防止中文乱码） -->
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- INFO 级别日志文件 -->
    <appender name="file_info" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${SERVICE_LOG_PATH}/info.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按天生成文件夹 + 按小时生成文件 -->
            <!-- 
                 %d{yyyy-MM-dd} - 日期文件夹
                 %d{yyyy-MM-dd_HH} - 小时文件名
                 %i            - 序号（超过 100MB 时递增）
                 
                 生成的文件路径示例：
                 - D:/IdeaProjects/nexusmall/logs/nexusmall-product/2026-03-25/info.2026-03-25_15.0.log
                 - D:/IdeaProjects/nexusmall/logs/nexusmall-product/2026-03-25/info.2026-03-25_15.1.log
            -->
            <fileNamePattern>${SERVICE_LOG_PATH}/%d{yyyy-MM-dd}/info.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
            <cleanHistoryOnStart>false</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 异步 INFO 日志 Appender（包装器） -->
    <!-- 💡 用途：将 INFO 日志记录异步化，避免磁盘 IO 阻塞业务线程 -->
    <appender name="async_file_info" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 队列大小（INFO 日志量大，设置大一些） -->
        <queueSize>1024</queueSize>
        <!-- 
             丢弃策略阈值：
             20 = 当队列剩余空间低于 20% 时开始丢弃 TRACE/WARN/DEBUG 级别的日志
             INFO 及以上级别不会丢弃
        -->
        <discardingThreshold>20</discardingThreshold>
        <!-- 是否包含调用者信息（true=性能较差，false=性能更好） -->
        <includeCallerData>false</includeCallerData>
        <!-- 引用实际的 INFO 文件 Appender -->
        <appender-ref ref="file_info"/>
    </appender>

    <!-- WARN 级别日志文件 -->
    <appender name="file_warn" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${SERVICE_LOG_PATH}/warn.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按天生成文件夹 + 按小时生成文件 -->
            <fileNamePattern>${SERVICE_LOG_PATH}/%d{yyyy-MM-dd}/warn.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
            <cleanHistoryOnStart>false</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 异步 WARN 日志 Appender（包装器） -->
    <!-- 💡 用途：将 WARN 日志记录异步化，避免磁盘 IO 阻塞业务线程 -->
    <appender name="async_file_warn" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 队列大小 -->
        <queueSize>512</queueSize>
        <!-- 
             丢弃策略阈值：
             20 = 当队列剩余空间低于 20% 时开始丢弃 TRACE/DEBUG 级别的日志
             WARN 及以上级别不会丢弃
        -->
        <discardingThreshold>20</discardingThreshold>
        <!-- 是否包含调用者信息（true=性能较差，false=性能更好） -->
        <includeCallerData>false</includeCallerData>
        <!-- 引用实际的 WARN 文件 Appender -->
        <appender-ref ref="file_warn"/>
    </appender>

    <!-- ERROR 级别日志文件 -->
    <appender name="file_error" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${SERVICE_LOG_PATH}/error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按天生成文件夹 + 按小时生成文件 -->
            <fileNamePattern>${SERVICE_LOG_PATH}/%d{yyyy-MM-dd}/error.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
            <cleanHistoryOnStart>false</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 异步 ERROR 日志 Appender（包装器） -->
    <!-- 💡 用途：将 ERROR 日志记录异步化，避免磁盘 IO 阻塞业务线程 -->
    <appender name="async_file_error" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 队列大小 -->
        <queueSize>512</queueSize>
        <!-- 
             丢弃策略阈值：
             0 = 不丢弃任何日志（推荐用于 ERROR 日志）
             queueSize 的百分比 = 当队列剩余空间低于此值时开始丢弃
        -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 是否包含调用者信息（true=性能较差，false=性能更好） -->
        <includeCallerData>false</includeCallerData>
        <!-- 引用实际的 ERROR 文件 Appender -->
        <appender-ref ref="file_error"/>
    </appender>

    <!-- 全部日志文件（包含所有级别，用于完整追溯） -->
    <appender name="file_all" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${SERVICE_LOG_PATH}/all.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按天生成文件夹 + 按小时生成文件 -->
            <fileNamePattern>${SERVICE_LOG_PATH}/%d{yyyy-MM-dd}/all.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>15</maxHistory>
            <totalSizeCap>20GB</totalSizeCap>
            <cleanHistoryOnStart>false</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- ===============================
         Kafka 日志收集 Appender（生产环境启用）
         =============================== -->
    <!-- 
        📌 生产环境配置说明：
        1. Kafka Appender 会在应用启动时尝试连接 Kafka Broker
        2. 使用 AsynchronousDeliveryStrategy 异步发送，不阻塞业务线程
        3. 如果 Kafka 不可用，会降级到 console appender（不会终止应用）
        4. 生产环境必须确保 Kafka 服务可用
        
        🔧 可靠性增强措施：
        1. 多 Broker 地址 - 提高可用性（至少 3 个节点）
        2. acks=all - 确保所有 ISR 副本写入成功
        3. 重试机制 - 无限重试 + 指数退避
        4. 幂等性 - 保证 exactly-once 语义
        5. 压缩 - 减少网络传输量
        6. 本地缓存 - Kafka 不可用时暂存日志
        
        官方文档：https://github.com/danielwegener/logback-kafka-appender
    -->
    <appender name="kafka" class="com.github.danielwegener.logback.kafka.KafkaAppender">
        <!-- 日志发送到 Kafka 的 topic -->
        <topic>app-logs</topic>
        
        <!-- Key 策略：按服务名 + 线程名分区，确保日志有序性 -->
        <keyingStrategy class="com.github.danielwegener.logback.kafka.keying.HostNameKeyingStrategy" />
        
        <!-- 发送策略：异步非阻塞发送 -->
        <deliveryStrategy class="com.github.danielwegener.logback.kafka.delivery.AsynchronousDeliveryStrategy" />
            
        <!-- Kafka Producer 配置 - 高可靠版本 -->
        <!-- 【关键】多 Broker 地址 - 提高可用性（生产环境至少配置 3 个节点） -->
        <!-- 格式：host1:port1,host2:port2,host3:port3 -->
        <!-- 注意：本地开发时可能无法解析 K8s 域名，可通过环境变量 KAFKA_SERVERS 覆盖 -->
        <producerConfig>bootstrap.servers=mall-kafka-ok-kafka-bootstrap.kafka.svc:9092</producerConfig>
        
        <!-- 【关键】acks=all - 确保所有 ISR 副本都写入成功才确认 -->
        <!-- 选项：0=不确认，1=leader 确认，all/all=-1=所有 ISR 副本确认 -->
        <producerConfig>acks=all</producerConfig>
        
        <!-- 【关键】启用幂等性 - 保证 exactly-once 语义，避免重复日志 -->
        <!-- 注意：enable.idempotence=true 时，retries 会自动设置为 Integer.MAX_VALUE -->
        <producerConfig>enable.idempotence=true</producerConfig>
        
        <!-- 【关键】重试配置 - 无限重试 + 指数退避 -->
        <!-- delivery.timeout.ms = linger.ms + request.timeout.ms + max.block.ms -->
        <producerConfig>retries=2147483647</producerConfig>
        <producerConfig>delivery.timeout.ms=120000</producerConfig>
        <producerConfig>retry.backoff.ms=100</producerConfig>
        
        <!-- 【性能】批量处理优化 - 提升吞吐量 -->
        <producerConfig>batch.size=32768</producerConfig> <!-- 32KB -->
        <producerConfig>linger.ms=50</producerConfig> <!-- 等待 50ms 或达到 batch.size -->
        <producerConfig>compression.type=lz4</producerConfig> <!-- 压缩算法：none, gzip, snappy, lz4, zstd -->
        
        <!-- 【可靠性】超时与阻塞配置 - 避免启动时阻塞 -->
        <producerConfig>request.timeout.ms=5000</producerConfig> <!-- 请求超时 5 秒（快速失败） -->
        <producerConfig>max.block.ms=1000</producerConfig> <!-- 阻塞最大 1 秒（避免阻塞启动） -->
        <producerConfig>metadata.max.age.ms=300000</producerConfig> <!-- 元数据刷新间隔 5 分钟 -->
        
        <!-- 【监控】客户端标识 -->
        <producerConfig>client.id=${APP_NAME:-unknown}-logback-kafka-${HOSTNAME:-unknown}</producerConfig>
        
        <!-- 【可靠性】拦截器 - 记录发送失败事件（可选） -->
        <!-- 可以在这里添加自定义拦截器来监控日志发送状态 -->
        <!-- <producerConfig>interceptor.classes=com.nexusmall.common.kafka.LoggingInterceptor</producerConfig> -->
        
        <!-- JSON 编码器：将日志编码为 JSON 格式，便于 ELK/EFK 解析 -->
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <!-- 时间戳字段 -->
                <timestamp><timeZone>Asia/Shanghai</timeZone></timestamp>
                
                <!-- 自定义字段：日志级别、服务名、链路追踪 ID 等 -->
                <pattern>
                    <pattern>{
                        "level": "%level",
                        "service": "${APP_NAME:-unknown}",
                        "traceId": "%X{traceId:-}",
                        "spanId": "%X{spanId:-}",
                        "thread": "%thread",
                        "logger": "%logger{36}",
                        "host": "${HOSTNAME:-unknown}",
                        "timestamp_unix": "%d{yyyy-MM-dd HH:mm:ss.SSS}"
                    }</pattern>
                </pattern>
                
                <!-- 日志消息内容 -->
                <message />
                
                <!-- 异常堆栈信息 -->
                <stackTrace>
                    <fieldName>stackTrace</fieldName>
                    <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                        <!-- 最大递归深度：30 层 -->
                        <maxDepthPerThrowable>30</maxDepthPerThrowable>
                        <!-- 最大长度：4096 字符（增加长度以保留完整堆栈） -->
                        <maxLength>4096</maxLength>
                        <!-- 根本原因优先显示 -->
                        <rootCauseFirst>true</rootCauseFirst>
                        <!-- 缩短类名 -->
                        <shortenedClassNameLength>20</shortenedClassNameLength>
                    </throwableConverter>
                </stackTrace>
            </providers>
        </encoder>
        
        <!-- Kafka 发送失败时的降级策略：输出到控制台 -->
        <appender-ref ref="console"/>
    </appender>
    
    <!-- 异步 Kafka Appender（包装器）- 增强可靠性版本 -->
    <!-- 💡 用途：异步发送 Kafka 日志，不阻塞业务线程 -->
    <appender name="async_kafka" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 【可靠性】队列大小：增加到 1024，应对突发流量 -->
        <queueSize>1024</queueSize>
        
        <!-- 【可靠性】丢弃策略阈值：0=永不丢弃（确保重要日志不丢失） -->
        <!-- 注意：如果队列满，会阻塞业务线程（权衡可靠性与性能） -->
        <discardingThreshold>0</discardingThreshold>
        
        <!-- 【可靠性】永不阻塞：true=队列满时丢弃日志，false=阻塞 -->
        <!-- 生产环境建议：false（宁可阻塞也不丢日志） -->
        <neverBlock>false</neverBlock>
        
        <!-- 【可靠性】最大刷新时间：应用关闭时等待日志发送完成的时间 -->
        <!-- 增加到 10 秒，确保 shutdown 时日志全部发送 -->
        <maxFlushTime>10000</maxFlushTime>
        
        <!-- 【可靠性】包含调用者信息：用于定位日志来源 -->
        <includeCallerData>false</includeCallerData>
        
        <!-- 引用实际的 Kafka Appender -->
        <appender-ref ref="kafka"/>
    </appender>

    <!-- ===============================
         分环境日志配置（Spring Profile）
         =============================== -->

    <!-- 开发环境（dev）配置 -->
    <springProfile name="dev">
        <!-- Seata 分布式事务详细日志 -->
        <!-- 💡 用途：查看分布式事务的完整执行流程 -->
        <logger name="io.seata" level="DEBUG"/>
        <logger name="io.seata.core.rpc" level="DEBUG"/>
        <logger name="io.seata.core.protocol" level="DEBUG"/>
        <logger name="io.seata.rm" level="DEBUG"/>
        <logger name="io.seata.rm.datasource" level="DEBUG"/>
        <logger name="io.seata.rm.datasource.undo" level="DEBUG"/>
        <logger name="io.seata.tm" level="DEBUG"/>
        <logger name="io.seata.spring.annotation" level="DEBUG"/>
        <logger name="io.seata.sqlparser" level="DEBUG"/>
        <logger name="io.seata.core.context" level="DEBUG"/>

        <!-- MyBatis SQL 执行日志 -->
        <!-- 💡 用途：查看 SQL 执行情况，调试数据库操作 -->
        <logger name="com.nexusmall.product.config.SeataHandlerInterceptor" level="DEBUG"/>
        <logger name="com.nexusmall.product.config.WebConfig" level="DEBUG"/>

        <!-- Druid 连接池日志 -->
        <!-- 💡 用途：监控数据库连接池状态 -->
        <logger name="com.alibaba.druid.pool" level="DEBUG"/>

        <!-- Nacos 客户端日志 -->
        <!-- 💡 用途：记录 Nacos 配置加载、服务发现等日志 -->
        <logger name="com.alibaba.nacos" level="DEBUG"/>
        <logger name="com.alibaba.nacos.client" level="DEBUG"/>
        <logger name="com.alibaba.nacos.client.config" level="DEBUG"/>

        <!-- 根日志配置 -->
        <!--
             level="DEBUG": 开发环境输出 DEBUG 及以上级别的日志
             appender-ref: 引用上面定义的输出目标
             
             💡 开发环境启用 Kafka 日志收集：
             1. 用于本地调试和日志集中收集
             2. 确保本地 Kafka 服务可用
             3. 如果 Kafka 不可用，会降级到 console（不会阻塞启动）
        -->
        <root level="DEBUG">
            <appender-ref ref="console"/>           <!-- 输出到控制台 -->
            <appender-ref ref="async_file_info"/>   <!-- 输出 INFO 日志（异步） -->
            <appender-ref ref="async_file_warn"/>   <!-- 输出 WARN 日志（异步） -->
            <appender-ref ref="async_file_error"/>  <!-- 输出 ERROR 日志（异步） -->
            <appender-ref ref="file_all"/>          <!-- 输出全部日志（同步） -->
            <appender-ref ref="async_kafka"/>       <!-- 输出到 Kafka（异步） -->
        </root>
    </springProfile>

    <!-- ===============================
         生产环境（prod）配置
         =============================== -->
    <springProfile name="prod">
        <!-- 根日志配置 -->
        <!--
             💡 生产环境配置要点：
             1. 日志级别为 INFO（不输出 DEBUG 详细日志）
             2. 必须开启 Kafka 日志收集（集中式日志管理）
             3. 所有文件日志均使用异步 Appender 提升性能
             4. Seata、Nacos 等框架日志调整为 INFO 或 WARN
             5. 确保 Kafka 服务可用，否则日志会降级到 console
        -->
            
        <!-- 生产环境建议的日志级别 -->
        <logger name="io.seata" level="INFO"/>
        <logger name="com.alibaba.nacos" level="WARN"/>
        <logger name="com.alibaba.druid.pool" level="INFO"/>
            
        <root level="INFO">
            <appender-ref ref="async_file_info"/>   <!-- 输出 INFO 日志（异步） -->
            <appender-ref ref="async_file_warn"/>   <!-- 输出 WARN 日志（异步） -->
            <appender-ref ref="async_file_error"/>  <!-- 输出 ERROR 日志（异步） -->
            <appender-ref ref="file_all"/>          <!-- 输出全部日志（同步） -->
            <appender-ref ref="async_kafka"/>       <!-- 输出到 Kafka（异步） -->
        </root>
    </springProfile>
        
    <!-- ===============================
         测试环境（test）配置
         =============================== -->
    <springProfile name="test">
        <!-- 根日志配置 -->
        <!--
             💡 测试环境配置要点：
             1. 日志级别为 INFO（与生产环境一致）
             2. 启用 Kafka 日志收集
             3. 保留完整的文件日志用于问题排查
        -->
            
        <logger name="io.seata" level="INFO"/>
        <logger name="com.alibaba.nacos" level="INFO"/>
            
        <root level="INFO">
            <appender-ref ref="async_file_info"/>   <!-- 输出 INFO 日志（异步） -->
            <appender-ref ref="async_file_warn"/>   <!-- 输出 WARN 日志（异步） -->
            <appender-ref ref="async_file_error"/>  <!-- 输出 ERROR 日志（异步） -->
            <appender-ref ref="file_all"/>          <!-- 输出全部日志（同步） -->
            <appender-ref ref="async_kafka"/>       <!-- 输出到 Kafka（异步） -->
        </root>
    </springProfile>
</configuration>

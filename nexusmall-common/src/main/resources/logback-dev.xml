<?xml version="1.0" encoding="UTF-8"?>
<!-- =====================================================
     NexusMall 订单服务 - 测试环境日志配置
     =====================================================
     标准依据：Logback 官方文档 (https://logback.qos.ch/manual/configuration.html)
     
     加载优先级规则：
     1. logback.configurationFile 系统属性（最高）
     2. logback-test.xml ← 本文件（测试环境专用）
     3. logback.groovy
     4. logback.xml / logback-spring.xml
     
     说明：
     - 本文件位于 src/test/resources/，仅在测试环境生效
     - 自动覆盖主环境的 logback-spring.xml
     - 测试环境禁用 Kafka Appender（避免依赖外部中间件）
     - 启用 DEBUG 级别日志，便于调试和排查问题
     ===================================================== -->
<configuration>
    <!-- 包含 Spring Boot 默认日志配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ===============================
         自定义日志属性
         =============================== -->
    
    <!-- 日志输出格式（包含线程名、日志级别、类名） -->
    <!-- 测试环境不需要 traceId/spanId（无链路追踪），格式更简洁 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n"/>
    
    <!-- 测试日志路径（独立于主环境日志） -->
    <property name="LOG_PATH" value="./logs"/>
    <property name="APP_NAME" value="nexusmall-order"/>
    <property name="SERVICE_LOG_PATH" value="${LOG_PATH}/${APP_NAME}"/>

    <!-- ===============================
         Appender 配置（日志输出目的地）
         =============================== -->

    <!-- 控制台输出（测试时必须保留，便于实时查看） -->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- INFO 级别日志文件 -->
    <appender name="file_info" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 测试环境独立文件名，避免与主环境日志冲突 -->
        <file>${SERVICE_LOG_PATH}/test-info.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 测试日志保留 7 天即可 -->
            <fileNamePattern>${SERVICE_LOG_PATH}/test-info.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- WARN 级别日志文件 -->
    <appender name="file_warn" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${SERVICE_LOG_PATH}/test-warn.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${SERVICE_LOG_PATH}/test-warn.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ERROR 级别日志文件 -->
    <appender name="file_error" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${SERVICE_LOG_PATH}/test-error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${SERVICE_LOG_PATH}/test-error.%d{yyyy-MM-dd_HH}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory> <!-- ERROR 日志保留时间更长 -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ===============================
         Logger 配置（按包名控制日志级别）
         =============================== -->

    <!-- 项目代码：DEBUG 级别（便于调试） -->
    <logger name="com.nexusmall.order" level="DEBUG" additivity="false">
        <appender-ref ref="console"/>
        <appender-ref ref="file_info"/>
        <appender-ref ref="file_warn"/>
        <appender-ref ref="file_error"/>
    </logger>

    <!-- Spring Framework：INFO 级别（减少框架噪音） -->
    <logger name="org.springframework" level="INFO"/>
    
    <!-- Spring Boot：INFO 级别 -->
    <logger name="org.springframework.boot" level="INFO"/>
    
    <!-- Hibernate/SQL：DEBUG 级别（查看 SQL 执行情况） -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>
    
    <!-- MyBatis：DEBUG 级别（查看 SQL 执行情况） -->
    <logger name="com.nexusmall.order.mapper" level="DEBUG"/>

    <!-- ===============================
         根日志配置
         =============================== -->
    <!-- 
         测试环境根日志级别：DEBUG
         - 允许查看所有 DEBUG 级别日志
         - 便于调试和排查测试失败原因
         - 输出到控制台 + 文件
    -->
    <root level="DEBUG">
        <appender-ref ref="console"/>
        <appender-ref ref="file_info"/>
        <appender-ref ref="file_warn"/>
        <appender-ref ref="file_error"/>
    </root>
</configuration>

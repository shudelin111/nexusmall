<?xml version="1.0" encoding="UTF-8"?>
<!-- =====================================================
     NexusMall 开发环境 Logback 日志配置（无 Kafka）
     =====================================================
     文件用途：开发环境专用日志配置，移除 Kafka 日志收集功能
     适用场景：Kafka Broker 不可用时避免阻塞应用启动
     
     注意事项：
     1. 此配置不包含 Kafka Appender，避免启动失败
     2. 生产环境请使用 logback-spring.xml（包含 Kafka）
     3. 如需启用 Kafka，请参考 logback-spring.xml 中的注释说明
     ===================================================== -->
<configuration scan="true" scanPeriod="60 seconds">
    
    <!-- 定义日志输出格式 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-},%X{spanId:-}] %-5level %logger{36} - %msg%n"/>
    
    <!-- ===============================
         控制台 Appender
         =============================== -->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- ===============================
         文件 Appender（异步）
         =============================== -->
    <appender name="async_file_info" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>20</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="file_info"/>
    </appender>
    
    <appender name="file_info" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/info.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>
    
    <appender name="async_file_warn" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>20</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="file_warn"/>
    </appender>
    
    <appender name="file_warn" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/warn.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/warn.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>
    
    <appender name="async_file_error" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>20</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="file_error"/>
    </appender>
    
    <appender name="file_error" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>
    
    <appender name="file_all" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/all.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${nexusmall.logging.path:-./logs}/${spring.application.name:-unknown}/all.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>
    
    <!-- ===============================
         分环境日志配置
         =============================== -->
    
    <!-- 开发环境（dev）配置 -->
    <springProfile name="dev">
        <!-- Seata 分布式事务详细日志 -->
        <logger name="io.seata" level="DEBUG"/>
        <logger name="io.seata.core.rpc" level="DEBUG"/>
        <logger name="io.seata.rm.datasource" level="DEBUG"/>
        
        <!-- MyBatis SQL 执行日志 -->
        <logger name="com.nexusmall.product.config.SeataHandlerInterceptor" level="DEBUG"/>
        
        <!-- Druid 连接池日志 -->
        <logger name="com.alibaba.druid.pool" level="DEBUG"/>
        
        <!-- Nacos 客户端日志 -->
        <logger name="com.alibaba.nacos" level="DEBUG"/>
        
        <!-- 根日志配置 -->
        <root level="DEBUG">
            <appender-ref ref="console"/>
            <appender-ref ref="async_file_info"/>
            <appender-ref ref="async_file_warn"/>
            <appender-ref ref="async_file_error"/>
            <appender-ref ref="file_all"/>
        </root>
    </springProfile>
    
    <!-- 生产/测试环境（prod, test）配置 -->
    <springProfile name="prod,test">
        <root level="INFO">
            <appender-ref ref="async_file_warn"/>
            <appender-ref ref="async_file_error"/>
            <appender-ref ref="file_all"/>
        </root>
    </springProfile>
    
</configuration>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexusmall.auth.dao.RefreshTokenMapper">

    <resultMap id="BaseResultMap" type="com.nexusmall.auth.entity.RefreshToken">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="token" property="token"/>
        <result column="jti" property="jti"/>
        <result column="expire_time" property="expireTime"/>
        <result column="device_info" property="deviceInfo"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据 JTI 查询 Refresh Token -->
    <select id="findByJti" resultMap="BaseResultMap">
        SELECT * FROM sys_refresh_token
        WHERE jti = #{jti}
        LIMIT 1
    </select>

    <!-- 根据用户ID查询有效的 Refresh Token 列表 -->
    <select id="findValidByUserId" resultMap="BaseResultMap">
        SELECT * FROM sys_refresh_token
        WHERE user_id = #{userId}
          AND status = 1
          AND expire_time > NOW()
        ORDER BY create_time DESC
    </select>

    <!-- 使指定用户的某个 Token 失效 -->
    <update id="invalidateToken">
        UPDATE sys_refresh_token
        SET status = 0,
            update_time = NOW()
        WHERE user_id = #{userId}
          AND jti = #{jti}
    </update>

    <!-- 使指定用户的所有 Token 失效 (登出所有设备) -->
    <update id="invalidateAllTokens">
        UPDATE sys_refresh_token
        SET status = 0,
            update_time = NOW()
        WHERE user_id = #{userId}
          AND status = 1
    </update>

    <!-- 清理过期的 Refresh Token -->
    <delete id="cleanExpiredTokens">
        DELETE FROM sys_refresh_token
        WHERE expire_time &lt; NOW()
           OR status = 0
    </delete>

</mapper>

# =====================================================
# Docker Build Context 忽略文件配置
# =====================================================
# 作用：过滤不需要复制到 Docker 构建上下文中的文件
# 效果：减少上下文传输时间，提升构建速度 70%+
# =====================================================

# Maven 构建输出
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# IDE 配置文件
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.vscode/
*.swp
*.swo
*~

# Git 版本控制
.git/
.gitignore
.gitattributes

# CI/CD 配置 (不复制到构建上下文)
.gitlab-ci.yml
.travis.yml
Jenkinsfile
azure-pipelines.yml

# 文档和说明
*.md
docs/
HELP.md
LICENSE
NOTICE

# 日志文件
logs/
*.log

# 临时文件和备份
*.tmp
*.bak
*.swp
*~

# 测试相关文件 (生产镜像不需要)
src/test/
**/*Test.java
**/*Tests.java
test-classes/

# Docker 相关文件 (避免循环引用)
Dockerfile*
docker-compose*.yml
.docker/

# 脚本文件
*.sh
*.bat
*.ps1

# 其他不必要文件
.coverage
.cobertura/
cobertura.xml
checkstyle-result.xml
checkstyle-cachefile
findbugs.xml
spotbugs.xml

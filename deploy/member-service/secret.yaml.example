# ==============================================================================
# NexusMall Member Service Secret (模板)
# NexusMall 会员服务 Kubernetes 密钥配置
# ==============================================================================
# ⚠️ 重要安全提示：
# 1. 此文件为示例模板，不包含真实凭证
# 2. 生产环境请使用以下任一方式管理密钥：
#    - Kubernetes Secrets（Base64 编码）
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Azure Key Vault
# 3. 切勿将包含真实密码的文件提交到 Git 仓库
# 4. 建议使用 Sealed Secrets 或 External Secrets Operator
# ==============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: nexusmall-member-secret
  namespace: nexusmall
  labels:
    app: nexusmall-member
    app.kubernetes.io/name: nexusmall-member
    app.kubernetes.io/part-of: nexusmall

# 密钥类型：Opaque 表示任意用户定义数据
type: Opaque

# 数据字段（Base64 编码）
# 生成 Base64 编码的命令示例：
#   echo -n "your-password" | base64
data:
  # MySQL 数据库凭证
  MYSQL_USERNAME: cm9vdA==                    # root (Base64)
  MYSQL_PASSWORD: MTIzNDU2                   # 123456 (Base64, 请修改为强密码)
  
  # Redis 凭证
  REDIS_PASSWORD: MTIzNDU2                    # 123456 (Base64, 请修改为强密码)
  
  # Nacos 认证凭证
  NACOS_USERNAME: bmFjb3M=                    # nacos (Base64)
  NACOS_PASSWORD: bmFjb3M=                    # nacos (Base64, 生产环境请修改)

# ==============================================================================
# NexusMall Third Party Service Secret (模板)
# NexusMall 第三方服务集成 Kubernetes 密钥配置
# ==============================================================================
# ⚠️ 重要安全提示：
# 1. 此文件为示例模板，不包含真实凭证
# 2. 生产环境请使用以下任一方式管理密钥：
#    - Kubernetes Secrets（Base64 编码）
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Azure Key Vault
# 3. 切勿将包含真实密码的文件提交到 Git 仓库
# 4. 建议使用 Sealed Secrets 或 External Secrets Operator
# ==============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: nexusmall-third-party-secret
  namespace: nexusmall
  labels:
    app: nexusmall-third-party
    app.kubernetes.io/name: nexusmall-third-party
    app.kubernetes.io/part-of: nexusmall

# 密钥类型：Opaque 表示任意用户定义数据
type: Opaque

# 数据字段（Base64 编码）
# 生成 Base64 编码的命令示例：
#   echo -n "your-password" | base64
data:
  # Redis 凭证
  REDIS_PASSWORD: MTIzNDU2                    # 123456 (Base64, 请修改为强密码)
  
  # Nacos 认证凭证
  NACOS_USERNAME: bmFjb3M=                    # nacos (Base64)
  NACOS_PASSWORD: bmFjb3M=                    # nacos (Base64, 生产环境请修改)
  
  # ========================================
  # 第三方服务敏感配置
  # ========================================
  
  # 阿里云 AccessKey（短信、OSS共用）
  ALIYUN_ACCESS_KEY_ID: eW91ci1hY2Nlc3Mta2V5LWlk          # your-access-key-id (Base64, 请替换为真实值)
  ALIYUN_ACCESS_KEY_SECRET: eW91ci1hY2Nlc3Mta2V5LXNlY3JldA==  # your-access-key-secret (Base64, 请替换为真实值)
  
  # 阿里云 OSS 配置
  ALIYUN_OSS_ENDPOINT: b3NzLWNuLWhhbmd6aG91LmFsaXl1bmNzLmNvbQ==  # oss-cn-hangzhou.aliyuncs.com (Base64)
  ALIYUN_OSS_BUCKET: bnV4dXNtYWxsLW9zcw==                        # nexusmall-oss (Base64)
  
  # MinIO 对象存储凭证
  MINIO_ACCESS_KEY: bWluaW9hZG1pbg==    # minioadmin (Base64)
  MINIO_SECRET_KEY: bWluaW9hZG1pbg==    # minioadmin (Base64)


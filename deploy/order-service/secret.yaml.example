# ==============================================================================
# NexusMall Order Service Secret (Example)
# NexusMall 订单服务密钥配置示例
# ==============================================================================
# 
# ⚠️ 重要提示：
# 1. 这是示例文件，不包含真实密码
# 2. 实际使用时，请复制此文件为 secret.yaml 并填入真实密码
# 3. 不要将包含真实密码的 secret.yaml 提交到 Git
# 
# 使用方法：
# 1. 复制此文件：cp secret.yaml.example secret.yaml
# 2. 生成 Base64 编码：
#    - Linux/Mac: echo -n 'your-password' | base64
#    - Windows PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes('your-password'))
# 3. 替换下面的占位值
# 4. 应用配置：kubectl apply -f secret.yaml
# ==============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: nexusmall-order-secret
  namespace: nexusmall
  labels:
    app: nexusmall-order
    app.kubernetes.io/name: nexusmall-order
    app.kubernetes.io/part-of: nexusmall

type: Opaque

data:
  # MySQL 用户名（请将 'cm9vdA==' 替换为实际值的 Base64 编码）
  # 示例：echo -n 'root' | base64  →  cm9vdA==
  MYSQL_USERNAME: cm9vdA==
  
  # MySQL 密码（请替换为强密码的 Base64 编码）
  # 示例：echo -n 'YourStrongPassword123!' | base64
  MYSQL_PASSWORD: MTIzNDU2
  
  # Redis 密码（请替换为强密码的 Base64 编码）
  # 示例：echo -n 'YourRedisPassword456!' | base64
  REDIS_PASSWORD: MTIzNDU2

# ==============================================================================
# NexusMall Notification Service Secret (模板)
# NexusMall 通知服务 Kubernetes 密钥配置
# ==============================================================================
# ⚠️ 重要安全提示：
# 1. 此文件为示例模板，不包含真实凭证
# 2. 生产环境请使用以下任一方式管理密钥：
#    - Kubernetes Secrets（Base64 编码）
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Azure Key Vault
# 3. 切勿将包含真实密码的文件提交到 Git 仓库
# 4. 建议使用 Sealed Secrets 或 External Secrets Operator
# ==============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: nexusmall-notification-secret
  namespace: nexusmall
  labels:
    app: nexusmall-notification
    app.kubernetes.io/name: nexusmall-notification
    app.kubernetes.io/part-of: nexusmall

type: Opaque

data:
  MYSQL_USERNAME: cm9vdA==
  MYSQL_PASSWORD: MTIzNDU2
  REDIS_PASSWORD: MTIzNDU2
  NACOS_USERNAME: bmFjb3M=
  NACOS_PASSWORD: bmFjb3M=

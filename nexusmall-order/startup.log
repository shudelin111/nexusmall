# ===============================
# Spring 搴旂敤閰嶇疆
# ===============================
spring:
  # 搴旂敤鍚嶇О
  application:
    name: nexusmall-order
  
  # Redis 閰嶇疆
  redis:
    # Redis 鏈嶅姟鍣ㄥ湴鍧€
    host: ${REDIS_HOST:10.10.1.1}
    # Redis 绔彛
    port: ${REDIS_PORT:6379}
    # 浣跨敤鐨勬暟鎹簱缂栧彿
    database: ${REDIS_DATABASE:0}
    # Redis 瀵嗙爜
    password: ${REDIS_PASSWORD:123456}
    # 杩炴帴瓒呮椂鏃堕棿锛堟绉掞級
    timeout: 5000  # 5 绉?    # Lettuce 杩炴帴姹犻厤缃?    lettuce:
      pool:
        # 鏈€澶ф椿璺冭繛鎺ユ暟
        max-active: 16
        # 鏈€澶х┖闂茶繛鎺ユ暟
        max-idle: 8
        # 鏈€灏忕┖闂茶繛鎺ユ暟
        min-idle: 0
        # 鑾峰彇杩炴帴鐨勬渶澶х瓑寰呮椂闂达紙姣锛?        max-wait: 1000ms  # 1 绉?  
  # Spring Cloud 閰嶇疆
  cloud:
    # OpenFeign 鏈嶅姟璋冪敤閰嶇疆
    openfeign:
      sentinel:
        enabled: true
      client:
        config:
          default:
            # 杩炴帴瓒呮椂
            connectTimeout: 5000
            # 璇诲彇瓒呮椂
            readTimeout: 5000
      httpclient:
        enabled: true
      compression:
        request:
          enabled: true
        response:
          enabled: true
    
    # Sentinel 鐔旀柇闄愭祦閰嶇疆
    sentinel:
      # 鍚敤 Sentinel
      enabled: true
      # 鍙栨秷鎺у埗鍙版噿鍔犺浇锛堝惎鍔ㄦ椂绔嬪嵆娉ㄥ唽鍒?Dashboard锛?      eager: true
      transport:
        dashboard: 10.10.1.1:8858
        port: 8719
      datasource:
        # 娴佹帶瑙勫垯鏁版嵁婧?        ds1:
          nacos:
            server-addr: 10.10.1.1:8848
            namespace: ""
            dataId: nexusmall-order-flow-rule.json
            groupId: DEFAULT_GROUP
            rule-type: flow
            data-type: json
            username: nacos
            password: nacos
        
        # 鐔旀柇闄嶇骇瑙勫垯鏁版嵁婧?        ds2:
          nacos:
            server-addr: 10.10.1.1:8848
            namespace: ""
            dataId: nexusmall-order-degrade-rule.json
            groupId: DEFAULT_GROUP
            rule-type: degrade
            data-type: json
            username: nacos
            password: nacos
        
        # 绯荤粺鑷€傚簲淇濇姢瑙勫垯鏁版嵁婧?        ds3:
          nacos:
            server-addr: 10.10.1.1:8848
            namespace: ""
            dataId: nexusmall-order-system-rule.json
            groupId: DEFAULT_GROUP
            rule-type: system
            data-type: json
            username: nacos
            password: nacos

# ===============================
# MyBatis-Plus 閰嶇疆
# ===============================
mybatis-plus:
  # Mapper XML 鏂囦欢浣嶇疆
  mapper-locations: classpath*:/mapper/**/*.xml
  # 瀹炰綋绫诲埆鍚嶅寘璺緞
  type-aliases-package: com.nexusmall.order.entity
  # MyBatis 鍘熺敓閰嶇疆
  configuration:
    # 寮€鍚┘宄板懡鍚嶈浆鎹?    map-underscore-to-camel-case: true
    # 绂佺敤浜岀骇缂撳瓨
    cache-enabled: false
    # SQL 鏃ュ織瀹炵幇绫?    log-impl: org.apache.ibatis.logging.slf4j.Slf4jImpl
  # 鍏ㄥ眬閰嶇疆
  global-config:
    db-config:
      # 涓婚敭鐢熸垚绛栫暐
      id-type: auto
      # 閫昏緫鍒犻櫎瀛楁
      logic-delete-field: deleted
      logic-delete-value: 1
      logic-not-delete-value: 0

# ===============================
# RocketMQ 閰嶇疆
# ===============================
rocketmq:
  # NameServer 鍦板潃
  name-server: 10.10.1.1:9876
  # 鐢熶骇鑰呴厤缃?  producer:
    group: order-producer-group
    send-message-timeout: 3000
    retry-times-when-send-failed: 2
    retry-times-when-send-async-failed: 2

# ===============================
# Seata 鍒嗗竷寮忎簨鍔￠厤缃?# ===============================
seata:
  enabled: true
  application-id: nexusmall-order
  tx-service-group: nexusmall-tx-group
  service:
    vgroup-mapping:
      nexusmall-tx-group: default
  registry:
    type: nacos
    nacos:
      server-addr: 10.10.1.1:8848
      namespace: ""
      group: SEATA_GROUP
      cluster: default
      username: nacos
      password: nacos
      application: seata-server
  config:
    type: nacos
    nacos:
      server-addr: 10.10.1.1:8848
      namespace: ""
      group: SEATA_GROUP
      username: nacos
      password: nacos
      data-id: seataServer.properties


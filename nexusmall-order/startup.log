    web:
      # 鏆撮湶鐨勭鐐瑰垪琛?      # 寮€鍙戠幆澧冿細鏆撮湶鎵€鏈夌鐐?      # 鐢熶骇鐜锛氬彧鏆撮湶 health,info,prometheus

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexusmall.logistics.infrastructure.persistence.mapper.LogisticsOrderMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.nexusmall.logistics.domain.entity.LogisticsOrder">
        <id column="id" property="id"/>
        <result column="order_sn" property="orderSn"/>
        <result column="member_id" property="memberId"/>
        <result column="warehouse_id" property="warehouseId"/>
        <result column="express_company" property="expressCompany"/>
        <result column="express_no" property="expressNo"/>
        <result column="receiver_name" property="receiverName"/>
        <result column="receiver_phone" property="receiverPhone"/>
        <result column="receiver_address" property="receiverAddress"/>
        <result column="status" property="status"/>
        <result column="ship_time" property="shipTime"/>
        <result column="receive_time" property="receiveTime"/>
        <result column="freight_amount" property="freightAmount"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, order_sn, member_id, warehouse_id, express_company, express_no,
        receiver_name, receiver_phone, receiver_address, status, ship_time,
        receive_time, freight_amount, remark, create_time, update_time
    </sql>

    <!-- 根据订单编号查询物流订单 -->
    <select id="selectByOrderSn" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM logistics_order
        WHERE order_sn = #{orderSn}
        LIMIT 1
    </select>

    <!-- 根据快递单号查询物流订单 -->
    <select id="selectByExpressNo" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM logistics_order
        WHERE express_no = #{expressNo}
        LIMIT 1
    </select>

</mapper>
